<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BitLockerUFCV.Client.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Activation BitLocker - UFCV">

    <Grid
        x:Name="RootGrid"
        Loaded="OnRootLoaded"
        Padding="24"
        RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Spacing="4">
            <TextBlock
                FontSize="24"
                FontWeight="SemiBold"
                Text="Activation BitLocker - UFCV" />
            <TextBlock
                Foreground="Gray"
                Text="Client Windows natif WinUI 3" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid Visibility="{Binding PinViewVisibility}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <TextBlock
                            TextWrapping="WrapWholeWords"
                            Visibility="{Binding SystemContextWarningVisibility}"
                            Text="{Binding SystemContextWarning}" />

                        <TextBlock
                            FontSize="28"
                            FontWeight="SemiBold"
                            Text="Protection des données" />
                        <TextBlock
                            TextWrapping="WrapWholeWords"
                            Text="La sécurité de vos données est essentielle pour l'UFCV. BitLocker chiffre le contenu de votre disque afin de rendre les informations illisibles en cas de vol ou d'accès non autorisé. Vos fichiers restent ainsi protégés, même si l'ordinateur quitte les locaux de l'UFCV." />
                        <TextBlock
                            TextWrapping="WrapWholeWords"
                            Text="Il vous suffit maintenant de choisir un code PIN de 6 à 20 chiffres, de préférence le même que celui utilisé pour ouvrir votre session, afin de sécuriser l'accès à votre poste au démarrage." />

                        <Grid
                            ColumnSpacing="16"
                            RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="Code PIN" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="Confirmation" />

                            <PasswordBox
                                x:Name="PinInputBox"
                                Grid.Row="1"
                                Grid.Column="0"
                                MaxLength="20"
                                PasswordChanged="OnPinPasswordChanged" />
                            <PasswordBox
                                x:Name="PinConfirmationBox"
                                Grid.Row="1"
                                Grid.Column="1"
                                MaxLength="20"
                                PasswordChanged="OnPinConfirmationPasswordChanged" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Foreground="DarkOrange"
                                TextWrapping="WrapWholeWords"
                                Text="{Binding PinValidationMessage}"
                                Visibility="{Binding PinValidationVisibility}" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                Foreground="DarkOrange"
                                TextWrapping="WrapWholeWords"
                                Text="{Binding PinConfirmationValidationMessage}"
                                Visibility="{Binding PinConfirmationValidationVisibility}" />
                        </Grid>

                        <TextBlock
                            HorizontalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{Binding PostponeCounterBrush}"
                            Text="{Binding PostponeCounterText}" />

                        <StackPanel
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="12">
                            <Button
                                Click="OnPostponeClicked"
                                Content="{Binding PostponeButtonText}"
                                IsEnabled="{Binding CanPostpone}" />
                            <Button
                                Click="OnValidateClicked"
                                Content="Valider"
                                IsEnabled="{Binding CanValidate}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid Visibility="{Binding ProgressViewVisibility}">
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Text="Configuration BitLocker" />
                    <TextBlock
                        Grid.Row="1"
                        TextWrapping="WrapWholeWords"
                        Text="{Binding ProgressStatusText}" />

                    <StackPanel
                        Grid.Row="2"
                        Spacing="12">
                        <ProgressBar
                            Height="12"
                            Minimum="0"
                            Maximum="100"
                            Value="{Binding ProgressValue}" />
                        <TextBlock Text="{Binding ProgressPercentText}" />
                        <ListView
                            IsItemClickEnabled="False"
                            ItemsSource="{Binding ProgressSteps}"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,8,0,8">
                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Text="{Binding StateLabel}" />
                                        <TextBlock
                                            TextWrapping="WrapWholeWords"
                                            Text="{Binding Message}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <Button
                        Grid.Row="3"
                        HorizontalAlignment="Right"
                        Click="OnFinishClicked"
                        Content="Fermer"
                        Visibility="{Binding FinishButtonVisibility}" />
                </Grid>
            </Grid>

            <Grid Visibility="{Binding LoadingOverlayVisibility}">
                <Border
                    Width="280"
                    Padding="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <StackPanel
                        HorizontalAlignment="Center"
                        Spacing="12">
                        <ProgressRing IsActive="True" />
                        <TextBlock Text="{Binding LoadingStatusText}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
