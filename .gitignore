# .NET / NuGet
# ------------------------------
artifacts/
.dotnet/
project.lock.json
project.fragment.lock.json

# NuGet packages (keep config, ignore packages folder)
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
!**/packages/repositories.config

